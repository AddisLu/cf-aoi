<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CfAoiControl.ViewModels"
             xmlns:m="using:CfAoiControl.Models"
             x:Class="CfAoiControl.Views.SystemSettingsView"
             x:DataType="vm:SystemSettingsViewModel">

  <DockPanel Margin="18" Background="{DynamicResource Bg}" TextElement.Foreground="{DynamicResource Txt}">
    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
      <TextBlock Grid.Column="0" Classes="h1" Text="系統設定" VerticalAlignment="Center"/>
      <TextBlock Grid.Column="1" Classes="mono dim" FontSize="12" VerticalAlignment="Center" Text="appsettings.json · GrabClient"/>
    </Grid>

    <TabControl Background="Transparent">

      <!-- ── 連線設定 ─── -->
      <TabItem Header="連線設定">
        <Grid ColumnDefinitions="*,*" Margin="0,12,0,0">
          <Border Grid.Column="0" Classes="card" Margin="0,0,7,0">
            <StackPanel Spacing="12">
              <TextBlock Classes="cardHead" Text="IP 連線"/>
              <Grid ColumnDefinitions="140,*">
                <Grid.RowDefinitions>
                  <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="IP Host" VerticalAlignment="Center" Foreground="{DynamicResource Txt2}"/>
                <TextBox  Grid.Row="0" Grid.Column="1" Text="{Binding IpHost}"/>
                <TextBlock Grid.Row="1" Text="IP Port" VerticalAlignment="Center" Foreground="{DynamicResource Txt2}"/>
                <TextBox  Grid.Row="1" Grid.Column="1" Text="{Binding IpPort}"/>
                <TextBlock Grid.Row="2" Text="上位機 Port" VerticalAlignment="Center" Foreground="{DynamicResource Txt2}"/>
                <TextBox  Grid.Row="2" Grid.Column="1" Text="{Binding UpstreamPort}"/>
                <TextBlock Grid.Row="3" Text="Recipe 目錄" VerticalAlignment="Center" Foreground="{DynamicResource Txt2}"/>
                <TextBox  Grid.Row="3" Grid.Column="1" Text="{Binding RecipeDir}"/>
                <TextBlock Grid.Row="4" Text="Output 目錄" VerticalAlignment="Center" Foreground="{DynamicResource Txt2}"/>
                <TextBox  Grid.Row="4" Grid.Column="1" Text="{Binding OutputDir}"/>
                <TextBlock Grid.Row="5" Text="影像目錄" VerticalAlignment="Center" Foreground="{DynamicResource Txt2}"/>
                <TextBox  Grid.Row="5" Grid.Column="1" Text="{Binding ImageDir}"/>
              </Grid>
              <StackPanel Orientation="Horizontal" Spacing="9">
                <Button Classes="primary" Content="測試連線" Command="{Binding TestConnectionCommand}"/>
              </StackPanel>
              <Border Background="{DynamicResource Bg3}" BorderBrush="{DynamicResource Line}" BorderThickness="1"
                      CornerRadius="{DynamicResource Rad}" Padding="11,9">
                <TextBlock Classes="mono" FontSize="12" Foreground="{DynamicResource Ok}" Text="{Binding TestResult}" TextWrapping="Wrap"/>
              </Border>
            </StackPanel>
          </Border>

          <Border Grid.Column="1" Classes="card" Margin="7,0,0,0" VerticalAlignment="Top">
            <StackPanel Spacing="12">
              <TextBlock Classes="cardHead" Text="節點狀態"/>
              <Border Background="{DynamicResource Bg3}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="{DynamicResource Rad}" Padding="11">
                <StackPanel Orientation="Horizontal" Spacing="11">
                  <Ellipse Width="10" Height="10" VerticalAlignment="Center"
                           Fill="{Binding IsGrabConnected, Converter={StaticResource BoolToGreenRed}}"/>
                  <StackPanel>
                    <TextBlock Text="Grab" Foreground="{DynamicResource Txt}"/>
                    <TextBlock Classes="mono dim" FontSize="11" Text="LIST_CAMERAS / SET_CAM_PARAMS"/>
                  </StackPanel>
                </StackPanel>
              </Border>
              <TextBlock Classes="dim" FontSize="11" TextWrapping="Wrap"
                         Text="（值來自 appsettings.json，無 hardcode；連線健康燈見頂列）"/>
            </StackPanel>
          </Border>
        </Grid>
      </TabItem>

      <!-- ── 相機參數（塊1：宣告陣列 + 偵測相機，兩者分開呈現） ─── -->
      <TabItem Header="相機參數">
        <ScrollViewer Margin="0,12,0,0">
        <StackPanel Spacing="12">

          <!-- 塊1：運算單元帶（宣告陣列，array_topology.json 驅動；全部未綁，綁定=#21） -->
          <Border Classes="card">
            <StackPanel Spacing="10">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Classes="cardHead" Text="運算單元 · 宣告陣列"/>
                <TextBlock Grid.Column="1" Classes="mono dim" FontSize="11" VerticalAlignment="Center" Text="{Binding TopologyStatus}"/>
              </Grid>
              <ItemsControl ItemsSource="{Binding ComputeUnits}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:ComputeUnitGroup">
                    <Border Background="{DynamicResource Bg3}" BorderBrush="{DynamicResource Line}" BorderThickness="1"
                            CornerRadius="{DynamicResource Rad}" Padding="11" Margin="0,0,0,8">
                      <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                          <Ellipse Width="10" Height="10" VerticalAlignment="Center" Fill="{DynamicResource Txt3}"/>
                          <TextBlock Text="{Binding Title}" FontWeight="Bold" Foreground="{DynamicResource Txt}" VerticalAlignment="Center"/>
                          <TextBlock Text="{Binding SubTitle}" Classes="mono dim" FontSize="11" VerticalAlignment="Center"/>
                          <TextBlock Text="{Binding SlotCountText}" Classes="dim" FontSize="11" VerticalAlignment="Center"/>
                          <TextBlock Text="· 連線/負載 = 塊2" Classes="dim" FontSize="10" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding Slots}">
                          <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="m:CcdSlotModel">
                              <Border Classes="chip" ToolTip.Tip="{Binding SlotStatusLabel}">
                                <StackPanel HorizontalAlignment="Center" Spacing="3">
                                  <Ellipse Width="14" Height="14" HorizontalAlignment="Center" Fill="{DynamicResource Warn}"/>
                                  <TextBlock Text="{Binding CcdId}" FontSize="10" FontFamily="{DynamicResource MonoFont}"
                                             HorizontalAlignment="Center" Foreground="{DynamicResource Txt}"/>
                                </StackPanel>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <TextBlock Classes="dim" FontSize="11" TextWrapping="Wrap"
                         Text="宣告槽全部「已宣告·未綁」（黃點）。實際 MAC↔CCD 綁定、線上/離線判定 = #21（Phase 2），不在此把列舉相機填進槽。"/>
            </StackPanel>
          </Border>

          <!-- 偵測到的相機（runtime；與上方宣告槽分開、未對映 = #21） -->
          <Border Classes="card">
          <StackPanel Spacing="12">
          <Grid ColumnDefinitions="Auto,*,Auto">
            <TextBlock Classes="cardHead" Text="偵測到的相機（runtime）" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Margin="10,0,0,0" Classes="mono dim" FontSize="11" VerticalAlignment="Center" Text="{Binding DetectedCamerasNote}"/>
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12">
              <TextBlock Text="{Binding CamStatus}" VerticalAlignment="Center" Foreground="{DynamicResource Txt3}" FontSize="11"/>
              <Button Classes="ghost" Content="↻ 列舉相機" Command="{Binding LoadCamerasCommand}" IsEnabled="{Binding IsGrabConnected}"/>
            </StackPanel>
          </Grid>

          <!-- KPI 列 -->
          <UniformGrid Columns="5">
            <Border Classes="card" Margin="0,0,8,0" Padding="13" ToolTip.Tip="配置 = 拓樸宣告 CCD 數（config），非 runtime 偵測；下方 4 個 KPI 才是偵測狀態">
              <StackPanel><TextBlock Classes="dim" FontSize="10.5" Text="配置(宣告)" Margin="0,0,0,6"/>
                <TextBlock Classes="mono" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource Txt}" Text="{Binding DeclaredSlotCount}"/></StackPanel>
            </Border>
            <Border Classes="card" Margin="0,0,8,0" Padding="13">
              <StackPanel><TextBlock Classes="dim" FontSize="10.5" Text="連線" Margin="0,0,0,6"/>
                <TextBlock Classes="mono" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource Ok}" Text="{Binding OnlineCount}"/></StackPanel>
            </Border>
            <Border Classes="card" Margin="0,0,8,0" Padding="13">
              <StackPanel><TextBlock Classes="dim" FontSize="10.5" Text="已綁定" Margin="0,0,0,6"/>
                <TextBlock Classes="mono" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource Accent}" Text="{Binding BoundCount}"/></StackPanel>
            </Border>
            <Border Classes="card" Margin="0,0,8,0" Padding="13">
              <StackPanel><TextBlock Classes="dim" FontSize="10.5" Text="待綁定" Margin="0,0,0,6"/>
                <TextBlock Classes="mono" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource Warn}" Text="{Binding UnboundCount}"/></StackPanel>
            </Border>
            <Border Classes="card" Padding="13">
              <StackPanel><TextBlock Classes="dim" FontSize="10.5" Text="離線" Margin="0,0,0,6"/>
                <TextBlock Classes="mono" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource Bad}" Text="{Binding OfflineCount}"/></StackPanel>
            </Border>
          </UniformGrid>

          <!-- 陣列 + 明細 -->
          <Grid ColumnDefinitions="*,320" MinHeight="300">
            <Border Grid.Column="0" Classes="card" Margin="0,0,12,0" Padding="6">
              <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ListBox Classes="camStrip" ItemsSource="{Binding Cameras}" SelectedItem="{Binding SelectedCamera}"
                         Background="Transparent" BorderThickness="0">
                  <ListBox.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                  </ListBox.ItemsPanel>
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="m:CameraInfoModel">
                      <Border Classes="chip" ToolTip.Tip="{Binding StatusLabel}">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                          <Ellipse Width="16" Height="16" HorizontalAlignment="Center"
                                   Fill="{Binding Status, Converter={StaticResource CamStatusToBrush}}"/>
                          <TextBlock Text="{Binding CamId, StringFormat='{}{0:00}'}" FontSize="12"
                                     FontFamily="{DynamicResource MonoFont}" HorizontalAlignment="Center" Foreground="{DynamicResource Txt}"/>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </ScrollViewer>
            </Border>

            <!-- 明細面板 -->
            <Border Grid.Column="1" Classes="card" IsVisible="{Binding HasSelection}" VerticalAlignment="Top">
              <StackPanel Spacing="10" DataContext="{Binding SelectedCamera}" x:DataType="m:CameraInfoModel">
                <StackPanel Orientation="Horizontal" Spacing="10">
                  <Ellipse Width="16" Height="16" VerticalAlignment="Center"
                           Fill="{Binding Status, Converter={StaticResource CamStatusToBrush}}"/>
                  <TextBlock Text="{Binding CcdLabel}" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding StatusLabel}" VerticalAlignment="Center" Foreground="{DynamicResource Txt3}"/>
                </StackPanel>
                <Grid ColumnDefinitions="64,*" RowDefinitions="Auto,Auto,Auto,Auto">
                  <TextBlock Grid.Row="0" Text="型號" Foreground="{DynamicResource Txt3}"/>
                  <TextBlock Grid.Row="0" Grid.Column="1" Classes="mono" Text="{Binding Model}"/>
                  <TextBlock Grid.Row="1" Text="MAC" Foreground="{DynamicResource Txt3}"/>
                  <TextBlock Grid.Row="1" Grid.Column="1" Classes="mono" Text="{Binding MacDisplay}"/>
                  <TextBlock Grid.Row="2" Text="IP" Foreground="{DynamicResource Txt3}"/>
                  <TextBlock Grid.Row="2" Grid.Column="1" Classes="mono" Text="{Binding IpDisplay}"/>
                  <TextBlock Grid.Row="3" Text="IP 設定" Foreground="{DynamicResource Txt3}"/>
                  <TextBlock Grid.Row="3" Grid.Column="1" Classes="mono dim" Text="{Binding IpConfig}"/>
                </Grid>

                <Border Height="1" Background="{DynamicResource Line}"/>

                <StackPanel Spacing="8" DataContext="{Binding $parent[UserControl].DataContext}" x:DataType="vm:SystemSettingsViewModel">
                  <TextBlock Text="相機設定（cam_config，機器層）" FontWeight="SemiBold" Foreground="{DynamicResource Txt}"/>
                  <Grid ColumnDefinitions="70,110,*" RowDefinitions="Auto,Auto">
                    <TextBlock Grid.Row="0" Text="曝光 µs" VerticalAlignment="Center" Foreground="{DynamicResource Txt2}"/>
                    <NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding ExposureUs}" Minimum="2" Maximum="10000" Increment="10" FormatString="F1"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding ExposureActualText}" Foreground="{DynamicResource Accent}" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <TextBlock Grid.Row="1" Text="增益 raw" VerticalAlignment="Center" Foreground="{DynamicResource Txt2}"/>
                    <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding GainRaw}" Minimum="256" Maximum="2047" Increment="64" FormatString="0"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding GainActualText}" Foreground="{DynamicResource Accent}" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/>
                  </Grid>
                  <Border Background="{DynamicResource Bg3}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="{DynamicResource Rad}" Padding="9">
                    <TextBlock Classes="mono" Text="{Binding MeanGrayText}" Foreground="{DynamicResource Ok}" FontSize="12" TextWrapping="Wrap"/>
                  </Border>
                  <StackPanel Orientation="Horizontal" Spacing="7">
                    <Button Classes="ghost" Content="讀取機器層參數" Command="{Binding ReadCamNodesCommand}" IsEnabled="{Binding IsGrabConnected}"/>
                    <Button Classes="ghost" Content="讀取" Command="{Binding RefreshCamParamsCommand}" IsEnabled="{Binding IsGrabConnected}"/>
                  </StackPanel>
                  <StackPanel Orientation="Horizontal" Spacing="7">
                    <Button Classes="ghost" Content="套用並驗證" Command="{Binding VerifyCamParamsCommand}" IsEnabled="{Binding IsGrabConnected}"
                            ToolTip.Tip="設曝光/增益後抓 1 幀算平均灰階,證明影像真的有變。取像中無法用。"/>
                    <Button Classes="primary" Content="套用" Command="{Binding ApplyCamParamsCommand}" IsEnabled="{Binding IsGrabConnected}"/>
                  </StackPanel>
                  <TextBlock Classes="mono dim" FontSize="11" Text="{Binding MachineParamsText}" TextWrapping="Wrap"/>
                  <TextBlock FontSize="11" Foreground="{DynamicResource Warn}" TextWrapping="Wrap"
                             Text="⚠ 綁定動作（指派 IP / 位置映射）= Gap #21，本版僅顯示狀態、不執行。"/>
                </StackPanel>
              </StackPanel>
            </Border>
          </Grid>
          </StackPanel>
          </Border>
        </StackPanel>
        </ScrollViewer>
      </TabItem>
    </TabControl>
  </DockPanel>

  <UserControl.Styles>
    <Style Selector="Border.chip">
      <Setter Property="Width" Value="50"/>
      <Setter Property="Background" Value="{DynamicResource Bg3}"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="BorderThickness" Value="2"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="Padding" Value="4,8"/>
      <Setter Property="Margin" Value="3"/>
    </Style>
    <Style Selector="ListBox.camStrip > ListBoxItem">
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Margin" Value="0"/>
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="ListBox.camStrip > ListBoxItem:selected /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="ListBox.camStrip > ListBoxItem:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="ListBox.camStrip > ListBoxItem:selected Border.chip">
      <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
      <Setter Property="Background" Value="{DynamicResource AccentSoft}"/>
    </Style>
  </UserControl.Styles>
</UserControl>
