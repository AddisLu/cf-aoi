<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CfAoiControl.ViewModels"
             x:Class="CfAoiControl.Views.SystemSettingsView"
             x:DataType="vm:SystemSettingsViewModel">
  <TabControl>

    <!-- ── 連線設定 tab（原有內容搬入；待 Mac 目視確認版面無誤）─── -->
    <TabItem Header="連線設定">
      <ScrollViewer>
        <StackPanel Margin="16" Spacing="10" MaxWidth="560" HorizontalAlignment="Left">
          <TextBlock Text="系統設定" FontSize="18" FontWeight="Bold"/>
          <TextBlock Text="（值來自 appsettings.json，無 hardcode）" Foreground="#888" FontSize="11"/>

          <Grid ColumnDefinitions="140,*">
            <Grid.RowDefinitions>
              <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="IP Host" VerticalAlignment="Center"/>
            <TextBox  Grid.Row="0" Grid.Column="1" Text="{Binding IpHost}"/>
            <TextBlock Grid.Row="1" Text="IP Port" VerticalAlignment="Center"/>
            <TextBox  Grid.Row="1" Grid.Column="1" Text="{Binding IpPort}"/>
            <TextBlock Grid.Row="2" Text="上位機 Port" VerticalAlignment="Center"/>
            <TextBox  Grid.Row="2" Grid.Column="1" Text="{Binding UpstreamPort}"/>
            <TextBlock Grid.Row="3" Text="RecipeDir" VerticalAlignment="Center"/>
            <TextBox  Grid.Row="3" Grid.Column="1" Text="{Binding RecipeDir}"/>
            <TextBlock Grid.Row="4" Text="OutputDir" VerticalAlignment="Center"/>
            <TextBox  Grid.Row="4" Grid.Column="1" Text="{Binding OutputDir}"/>
            <TextBlock Grid.Row="5" Text="ImageDir" VerticalAlignment="Center"/>
            <TextBox  Grid.Row="5" Grid.Column="1" Text="{Binding ImageDir}"/>
          </Grid>

          <StackPanel Orientation="Horizontal" Spacing="10">
            <Button Content="測試 IP 連線" Command="{Binding TestConnectionCommand}"/>
            <TextBlock Text="{Binding TestResult}" VerticalAlignment="Center"/>
          </StackPanel>
        </StackPanel>
      </ScrollViewer>
    </TabItem>

    <!-- ── 相機 tab（Gap #2：曝光/增益設定）───────────────────────── -->
    <TabItem Header="相機">
      <ScrollViewer>
        <StackPanel Margin="20" Spacing="16" MaxWidth="460" HorizontalAlignment="Left">

          <!-- 標題列：相機參數 + Grab 連線指示器 -->
          <StackPanel Orientation="Horizontal" Spacing="14">
            <TextBlock Text="相機參數" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
              <Ellipse Width="12" Height="12" VerticalAlignment="Center"
                       Fill="{Binding IsGrabConnected, Converter={StaticResource BoolToGreenRed}}"/>
              <TextBlock FontSize="14" Text="Grab 連線" VerticalAlignment="Center"/>
            </StackPanel>
          </StackPanel>

          <Grid ColumnDefinitions="90,180,*">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- CCD（唯讀，固定 0）-->
            <TextBlock Grid.Row="0" Text="CCD" FontSize="14" VerticalAlignment="Center" Margin="0,7"/>
            <TextBox Grid.Row="0" Grid.Column="1" Text="0" IsEnabled="False" Margin="0,7"/>
            <TextBlock Grid.Row="0" Grid.Column="2" Text="固定 cam_id = 0"
                       VerticalAlignment="Center" Foreground="#888" FontSize="13" Margin="10,7,0,7"/>

            <!-- 曝光 -->
            <TextBlock Grid.Row="1" Text="曝光 (µs)" FontSize="14" VerticalAlignment="Center" Margin="0,7"/>
            <NumericUpDown Grid.Row="1" Grid.Column="1" Margin="0,7"
                           Value="{Binding ExposureUs}"
                           Minimum="2" Maximum="10000" Increment="10"
                           FormatString="F1"/>
            <StackPanel Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Margin="10,7,0,7">
              <TextBlock Text="範圍 2 ~ 10000 µs" Foreground="#888" FontSize="13"/>
              <TextBlock Text="{Binding ExposureActualText}" Foreground="#3A7AFE" FontSize="13" FontWeight="SemiBold"/>
            </StackPanel>

            <!-- 增益 -->
            <TextBlock Grid.Row="2" Text="增益 raw" FontSize="14" VerticalAlignment="Center" Margin="0,7"/>
            <NumericUpDown Grid.Row="2" Grid.Column="1" Margin="0,7"
                           Value="{Binding GainRaw}"
                           Minimum="256" Maximum="2047" Increment="64"
                           FormatString="0"/>
            <StackPanel Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Margin="10,7,0,7">
              <TextBlock Text="範圍 256 ~ 2047" Foreground="#888" FontSize="13"/>
              <TextBlock Text="{Binding GainActualText}" Foreground="#3A7AFE" FontSize="13" FontWeight="SemiBold"/>
            </StackPanel>
          </Grid>

          <!-- 操作按鈕 -->
          <StackPanel Orientation="Horizontal" Spacing="10">
            <Button Content="套用" Padding="20,8" FontSize="14"
                    Command="{Binding ApplyCamParamsCommand}"
                    IsEnabled="{Binding IsGrabConnected}"/>
            <Button Content="讀取目前值" Padding="16,8" FontSize="14"
                    Command="{Binding RefreshCamParamsCommand}"
                    IsEnabled="{Binding IsGrabConnected}"/>
            <TextBlock Text="{Binding CamStatus}" FontSize="14" VerticalAlignment="Center" Margin="6,0,0,0"/>
          </StackPanel>

          <TextBlock Text="⚠ 曝光/增益為機器層設定（cam_config.json），套用後持久化於 Grab 端。"
                     FontSize="13" Foreground="#888" TextWrapping="Wrap"/>
        </StackPanel>
      </ScrollViewer>
    </TabItem>

  </TabControl>
</UserControl>
