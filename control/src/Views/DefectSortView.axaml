<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CfAoiControl.Views.DefectSortView"
             x:CompileBindings="False" Focusable="True">

  <UserControl.Styles>
    <Style Selector="DataGridColumnHeader">
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="FontWeight" Value="Bold"/>
    </Style>
  </UserControl.Styles>

  <DockPanel Margin="18" Background="{DynamicResource Bg}" TextElement.Foreground="{DynamicResource Txt}">
    <!-- 標題列 -->
    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
      <TextBlock Grid.Column="0" Classes="h1" Text="缺陷分類" VerticalAlignment="Center"/>
      <TextBlock Grid.Column="1" Classes="mono dim" FontSize="12" VerticalAlignment="Center" Text="frmSortDefect · 遠端歸檔 + 人工標註"/>
    </Grid>

    <Grid>
      <!-- ============ 第一層：資料夾列表 ============ -->
      <DockPanel IsVisible="{Binding InPatchView, Converter={StaticResource InverseBool}}">
        <!-- 工具列 -->
        <Border DockPanel.Dock="Top" Classes="card" Padding="12,10" Margin="0,0,0,12">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <StackPanel Spacing="4">
              <TextBlock Classes="dim" FontSize="10.5" Text="日期"/>
              <DatePicker SelectedDate="{Binding SelectedDate}"/>
            </StackPanel>
            <StackPanel Spacing="4">
              <TextBlock Classes="dim" FontSize="10.5" Text="輸出夾 (output/)"/>
              <TextBox Width="150" Text="{Binding OutputFolder}" Watermark="sorted"/>
            </StackPanel>
            <CheckBox Content="By ID 分組" IsChecked="{Binding ByIdFolder}" VerticalAlignment="Bottom"/>
            <CheckBox Content="Sort All（全選）" IsChecked="{Binding SortAll}" VerticalAlignment="Bottom"/>
            <Panel Width="20"/>
            <Button Classes="ghost" Content="Parse" VerticalAlignment="Bottom" Command="{Binding ParseCommand}"/>
            <Button Classes="gold" Content="Sort Defect" VerticalAlignment="Bottom"
                    IsEnabled="{Binding CanSort}" Command="{Binding SortCommand}"/>
          </StackPanel>
        </Border>
        <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True" IsVisible="{Binding IsSorting}" Height="4" Margin="0,0,0,8"/>

        <!-- DataGrid（雙擊 → 進入小圖分類）+ log -->
        <Border Classes="card" Padding="0">
          <DockPanel>
            <Border DockPanel.Dock="Bottom" BorderBrush="{DynamicResource Line}" BorderThickness="0,1,0,0" Padding="14,8">
              <TextBlock Classes="mono dim" FontSize="11" Text="（雙擊資料夾 → 進入小圖人工分類）"/>
            </Border>
            <DataGrid x:Name="FolderGrid" ItemsSource="{Binding Folders}" AutoGenerateColumns="False"
                      GridLinesVisibility="Horizontal" HeadersVisibility="Column" CanUserSortColumns="True"
                      IsReadOnly="False" Background="Transparent" BorderThickness="0">
              <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Sort" Binding="{Binding Sort}" Width="70"/>
                <DataGridTextColumn Header="資料夾名稱" Binding="{Binding FolderName}" IsReadOnly="True" Width="*"/>
                <DataGridTextColumn Header="Panel ID" Binding="{Binding PanelId}" IsReadOnly="True" Width="220"/>
                <DataGridTextColumn Header="缺陷數" Binding="{Binding DefectCount}" IsReadOnly="True" Width="90"/>
              </DataGrid.Columns>
            </DataGrid>
          </DockPanel>
        </Border>
      </DockPanel>

      <!-- ============ 第二層：小圖人工分類檢視 ============ -->
      <DockPanel IsVisible="{Binding InPatchView}">
        <!-- 頂部：返回 + 資料夾 + 統計 -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,11">
          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
            <Button Classes="ghost" Content="← 返回" Command="{Binding BackToFoldersCommand}"/>
            <TextBlock Text="{Binding CurrentFolder}" Classes="mono" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource Txt}"/>
          </StackPanel>
          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="999" Padding="11,4">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Ellipse Width="7" Height="7" Fill="{DynamicResource Txt3}" VerticalAlignment="Center"/>
                <TextBlock Text="全部" FontSize="11" Foreground="{DynamicResource Txt2}"/>
                <TextBlock Classes="mono" FontWeight="Bold" Text="{Binding TotalCount}"/>
              </StackPanel>
            </Border>
            <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="999" Padding="11,4">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Ellipse Width="7" Height="7" Fill="{DynamicResource Bad}" VerticalAlignment="Center"/>
                <TextBlock Text="TrueDefect" FontSize="11" Foreground="{DynamicResource Txt2}"/>
                <TextBlock Classes="mono" FontWeight="Bold" Text="{Binding TrueDefectCount}"/>
              </StackPanel>
            </Border>
            <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="999" Padding="11,4">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Ellipse Width="7" Height="7" Fill="{DynamicResource Accent}" VerticalAlignment="Center"/>
                <TextBlock Text="Particle" FontSize="11" Foreground="{DynamicResource Txt2}"/>
                <TextBlock Classes="mono" FontWeight="Bold" Text="{Binding ParticleCount}"/>
              </StackPanel>
            </Border>
            <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="999" Padding="11,4">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Ellipse Width="7" Height="7" Fill="{DynamicResource Warn}" VerticalAlignment="Center"/>
                <TextBlock Text="未分類" FontSize="11" Foreground="{DynamicResource Txt2}"/>
                <TextBlock Classes="mono" FontWeight="Bold" Text="{Binding UnclassifiedCount}"/>
              </StackPanel>
            </Border>
            <Button Classes="gold" Content="Sort（存分類歸檔）" Command="{Binding SaveClassificationCommand}"/>
          </StackPanel>
        </Grid>
        <!-- 篩選列 -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
          <TextBlock Text="篩選" VerticalAlignment="Center" Foreground="{DynamicResource Txt3}" FontSize="11"/>
          <ComboBox ItemsSource="{Binding Filters}" SelectedItem="{Binding SelectedFilter}" MinWidth="150"/>
          <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource Txt3}"
                     Text="鍵盤 T=TrueDefect · P=Particle · ←→ 切換"/>
        </StackPanel>
        <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True" IsVisible="{Binding IsLoadingPatches}" Height="4" Margin="0,0,0,8"/>

        <!-- 右：選中小圖放大 + 分類按鈕 -->
        <Border DockPanel.Dock="Right" Width="260" Classes="card" Margin="13,0,0,0">
          <DockPanel>
            <TextBlock DockPanel.Dock="Top" Classes="cardHead" Text="選中小圖（放大看細節）" Margin="0,0,0,8"/>
            <Border DockPanel.Dock="Top" Width="240" Height="240" Background="{DynamicResource ImageBackdrop}"
                    CornerRadius="{DynamicResource Rad}" BorderThickness="3"
                    BorderBrush="{Binding SelectedPatch.CurrentClass, Converter={StaticResource ClassToBorderBrush}}">
              <Image Source="{Binding SelectedPatch.Thumb}" Stretch="Uniform" RenderOptions.BitmapInterpolationMode="None"/>
            </Border>
            <TextBlock DockPanel.Dock="Top" Classes="mono" Text="{Binding SelectedPatch.Caption}" Margin="0,6" TextWrapping="Wrap" Foreground="{DynamicResource Txt2}"/>
            <TextBlock DockPanel.Dock="Top" Text="{Binding SelectedPatch.CurrentClass}" FontWeight="Bold"
                       Foreground="{Binding SelectedPatch.CurrentClass, Converter={StaticResource ClassToBorderBrush}}"/>
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="0,8">
              <Button Classes="bad" Content="TrueDefect (T)" Command="{Binding MarkTrueCommand}" CommandParameter="{Binding SelectedPatch}"/>
              <Button Classes="green" Content="Particle (P)" Command="{Binding MarkParticleCommand}" CommandParameter="{Binding SelectedPatch}"/>
            </StackPanel>
            <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Foreground="{DynamicResource Txt3}" FontSize="11"
                       Text="鍵盤：T=TrueDefect、P=Particle（標完自動下一張）；←→ 切換小圖。"/>
            <TextBlock/>
          </DockPanel>
        </Border>

        <!-- 中：縮圖牆 -->
        <Border Classes="card" Padding="2">
          <ListBox x:Name="PatchList" ItemsSource="{Binding Patches}" SelectedItem="{Binding SelectedPatch}"
                   Background="Transparent" BorderThickness="0"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemsPanel>
              <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border BorderThickness="2" Margin="3" Padding="6" Background="{DynamicResource Bg3}"
                        CornerRadius="{DynamicResource Rad}"
                        BorderBrush="{Binding CurrentClass, Converter={StaticResource ClassToBorderBrush}}">
                  <StackPanel Width="106">
                    <Border Height="88" Background="{DynamicResource ImageBackdrop}" CornerRadius="{DynamicResource Rad}" ClipToBounds="True">
                      <Image Source="{Binding Thumb}" Width="88" Height="88" Stretch="Uniform"
                             RenderOptions.BitmapInterpolationMode="None"/>
                    </Border>
                    <TextBlock Text="{Binding Caption}" Classes="mono" FontSize="9" Foreground="{DynamicResource Txt2}"
                               HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,5,0,4"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4">
                      <Button Classes="bad" Content="T" FontSize="10" Padding="10,1"
                              Command="{Binding $parent[ListBox].DataContext.MarkTrueCommand}" CommandParameter="{Binding}"/>
                      <Button Classes="green" Content="P" FontSize="10" Padding="10,1"
                              Command="{Binding $parent[ListBox].DataContext.MarkParticleCommand}" CommandParameter="{Binding}"/>
                    </StackPanel>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Border>
      </DockPanel>
    </Grid>
  </DockPanel>
</UserControl>
