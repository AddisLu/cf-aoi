<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CfAoiControl.ViewModels"
        xmlns:svc="using:CfAoiControl.Services"
        xmlns:views="using:CfAoiControl.Views"
        x:Class="CfAoiControl.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1280" Height="800" MinWidth="1100" MinHeight="700"
        Background="{DynamicResource Bg}"
        TransparencyLevelHint="None"
        Title="CF-AOI Control">

  <Design.DataContext><vm:MainWindowViewModel/></Design.DataContext>

  <DockPanel LastChildFill="True">

    <!-- ===================== 頂列 ===================== -->
    <Border DockPanel.Dock="Top" Height="52" Background="{DynamicResource Bar}"
            BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1">
      <Grid Margin="16,0" ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto">
        <!-- logo + title -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <Border Width="22" Height="22" CornerRadius="{DynamicResource Rad}" Background="{DynamicResource Accent}"/>
          <TextBlock Text="CF-AOI Control" FontFamily="{DynamicResource HeadFont}" FontWeight="Bold"
                     FontSize="15" Foreground="{DynamicResource Txt}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- 檢測模式徽章 -->
        <Border Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center"
                Background="{DynamicResource Bg3}" BorderBrush="{DynamicResource Line2}" BorderThickness="1"
                CornerRadius="999" Padding="10,3">
          <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
            <Ellipse Width="6" Height="6" Fill="{DynamicResource Warn}"/>
            <TextBlock Text="{Binding CurDetectMode}" Classes="mono" FontSize="11" Foreground="{DynamicResource Txt2}"/>
          </StackPanel>
        </Border>

        <!-- 命令 -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" Margin="16,0,0,0" VerticalAlignment="Center">
          <TextBlock Text="命令" Classes="mono" FontSize="12" Foreground="{DynamicResource Txt2}"/>
          <TextBlock Text="{Binding CurCommand}" Classes="mono" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource Accent}"/>
        </StackPanel>

        <!-- 連線指示燈 -->
        <Border Grid.Column="4" VerticalAlignment="Center" Margin="0,0,12,0"
                Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}" BorderThickness="1"
                CornerRadius="{DynamicResource Rad}" Padding="12,5">
          <StackPanel Orientation="Horizontal" Spacing="14">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Ellipse Width="9" Height="9" VerticalAlignment="Center" Classes="live"
                       Fill="{Binding IsIpConnected, Converter={StaticResource BoolToGreenRed}}"/>
              <TextBlock Text="IP" FontSize="11.5" Foreground="{DynamicResource Txt2}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Ellipse Width="9" Height="9" VerticalAlignment="Center" Classes="live"
                       Fill="{Binding IsGrabConnected, Converter={StaticResource BoolToGreenRed}}"/>
              <TextBlock Text="Grab" FontSize="11.5" Foreground="{DynamicResource Txt2}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Ellipse Width="9" Height="9" VerticalAlignment="Center" Classes="live"
                       Fill="{Binding IsUpstreamConnected, Converter={StaticResource BoolToGreenRed}}"/>
              <TextBlock Text="上位機" FontSize="11.5" Foreground="{DynamicResource Txt2}"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- A / B 外觀切換 -->
        <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <TextBlock Text="外觀" Classes="mono" FontSize="10" Foreground="{DynamicResource Txt3}" VerticalAlignment="Center"/>
          <Border Background="{DynamicResource Bg3}" BorderBrush="{DynamicResource Line}" BorderThickness="1"
                  CornerRadius="{DynamicResource Rad}" Padding="2">
            <StackPanel Orientation="Horizontal" Spacing="2">
              <Button x:Name="BtnVariantA" Classes="seg active" Content="A 控制室"/>
              <Button x:Name="BtnVariantB" Classes="seg" Content="B 實驗室"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ===================== 底部狀態列 ===================== -->
    <Border DockPanel.Dock="Bottom" Height="28" Background="{DynamicResource Bar}"
            BorderBrush="{DynamicResource Line}" BorderThickness="0,1,0,0">
      <Grid Margin="16,0" ColumnDefinitions="Auto,*,Auto,Auto">
        <TextBlock Grid.Column="0" Classes="mono dim" FontSize="11" VerticalAlignment="Center"
                   Text="{Binding CurRecipe, StringFormat='Recipe : {0}'}"/>
        <TextBlock Grid.Column="2" Classes="mono dim" FontSize="11" VerticalAlignment="Center" Margin="0,0,16,0" Text="就緒"/>
        <TextBlock Grid.Column="3" Classes="mono" FontSize="11" VerticalAlignment="Center"
                   Foreground="{DynamicResource Accent}" Text="CF-AOI · .NET 8 · Avalonia"/>
      </Grid>
    </Border>

    <!-- ===================== 主體：側欄 + 內容 ===================== -->
    <Grid ColumnDefinitions="212,*">

      <!-- 側欄 -->
      <Border Grid.Column="0" Background="{DynamicResource Bar}" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,1,0">
        <DockPanel Margin="10,14">
          <!-- 底部：作用中配方 -->
          <Border DockPanel.Dock="Bottom" Classes="card" Padding="10" Margin="0,10,0,0">
            <StackPanel>
              <TextBlock Text="作用中配方" FontSize="10" Foreground="{DynamicResource Txt3}" Margin="0,0,0,5"/>
              <TextBlock Text="{Binding Store.SelectedRecipe}" Classes="mono" FontSize="13" FontWeight="SemiBold"
                         Foreground="{DynamicResource Accent}"/>
            </StackPanel>
          </Border>

          <StackPanel Spacing="4">
            <TextBlock Text="驗證步驟" FontFamily="{DynamicResource HeadFont}" FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource Txt3}" Margin="10,6,0,4"/>
            <Button Classes="nav" Classes.active="{Binding IsDashboard}"
                    Command="{Binding NavigateCommand}" CommandParameter="dashboard" Content="主控台"/>
            <Button Classes="nav" Classes.active="{Binding IsStep1}"
                    Command="{Binding NavigateCommand}" CommandParameter="step1" Content="Step 1：演算法驗證"/>
            <Button Classes="nav" IsEnabled="False" ToolTip.Tip="MIL 對位專屬，新版未啟用" Content="Step 2-3：RDMA 驗證　(未啟用)"/>
            <Button Classes="nav" IsEnabled="False" ToolTip.Tip="MIL 對位專屬，新版未啟用" Content="Step 4：存圖模式　(未啟用)"/>
            <Button Classes="nav" IsEnabled="False" ToolTip.Tip="MIL 對位專屬，新版未啟用" Content="Step 5：完整生產　(未啟用)"/>

            <Border Height="1" Background="{DynamicResource Line}" Margin="6,10"/>

            <TextBlock Text="工具" FontFamily="{DynamicResource HeadFont}" FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource Txt3}" Margin="10,2,0,4"/>
            <Button Classes="nav" Classes.active="{Binding IsZone}"
                    Command="{Binding NavigateCommand}" CommandParameter="zone" Content="配方編輯"/>
            <Button Classes="nav" Classes.active="{Binding IsSort}"
                    Command="{Binding NavigateCommand}" CommandParameter="sort" Content="缺陷分類"/>
            <Button Classes="nav" Classes.active="{Binding IsSettings}"
                    Command="{Binding NavigateCommand}" CommandParameter="settings" Content="系統設定"/>
            <Button Classes="nav" Classes.active="{Binding IsSingleCcd}"
                    Command="{Binding NavigateCommand}" CommandParameter="singleccd"
                    ToolTip.Tip="從系統設定的宣告陣列點一顆 CCD 進入；可直接開啟（未選則顯提示）" Content="單 CCD 設定"/>
            <Button Classes="nav" IsEnabled="False" ToolTip.Tip="MIL 專屬，新版未啟用" Content="機況確認　(未啟用)"/>
          </StackPanel>
        </DockPanel>
      </Border>

      <!-- 內容區 -->
      <Panel Grid.Column="1" Background="{DynamicResource Bg}">

        <!-- ============ 主控台 ============ -->
        <Grid IsVisible="{Binding IsDashboard}" Margin="18" RowDefinitions="Auto,Auto,*" >
          <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,14">
            <TextBlock Grid.Column="0" Classes="h1" Text="主控台" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Classes="mono dim" FontSize="12" VerticalAlignment="Center"
                       Text="frmCfAoi · 上位機介面"/>
          </Grid>

          <!-- 狀態磚 -->
          <UniformGrid Grid.Row="1" Columns="6" Margin="0,0,0,14">
            <Border Classes="card" Margin="0,0,10,0" Padding="11,13">
              <StackPanel><TextBlock Classes="dim" FontSize="10.5" Text="目前命令" Margin="0,0,0,6"/>
                <TextBlock Classes="mono" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource Accent}" Text="{Binding CurCommand}"/></StackPanel>
            </Border>
            <Border Classes="card" Margin="0,0,10,0" Padding="11,13">
              <StackPanel><TextBlock Classes="dim" FontSize="10.5" Text="相機狀態" Margin="0,0,0,6"/>
                <TextBlock Classes="mono" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource Ok}" Text="{Binding CurCamStatus}"/></StackPanel>
            </Border>
            <Border Classes="card" Margin="0,0,10,0" Padding="11,13">
              <StackPanel><TextBlock Classes="dim" FontSize="10.5" Text="目前配方" Margin="0,0,0,6"/>
                <TextBlock Classes="mono" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource Txt}" Text="{Binding Store.SelectedRecipe}"/></StackPanel>
            </Border>
            <Border Classes="card" Margin="0,0,10,0" Padding="11,13">
              <StackPanel><TextBlock Classes="dim" FontSize="10.5" Text="Panel ID" Margin="0,0,0,6"/>
                <TextBlock Classes="mono" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource Txt}" Text="{Binding CurPanelId}"/></StackPanel>
            </Border>
            <Border Classes="card" Margin="0,0,10,0" Padding="11,13">
              <StackPanel><TextBlock Classes="dim" FontSize="10.5" Text="檢測模式" Margin="0,0,0,6"/>
                <TextBlock Classes="mono" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource Warn}" Text="{Binding CurDetectMode}"/></StackPanel>
            </Border>
            <Border Classes="card" Padding="11,13">
              <StackPanel><TextBlock Classes="dim" FontSize="10.5" Text="AI 模型" Margin="0,0,0,6"/>
                <TextBlock Classes="mono" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource Txt2}" Text="{Binding AiModel}"/></StackPanel>
            </Border>
          </UniformGrid>

          <Grid Grid.Row="2" ColumnDefinitions="360,*" >
            <!-- 左：命令 + 配方 -->
            <Grid Grid.Column="0" RowDefinitions="Auto,*" Margin="0,0,14,0">
              <Border Grid.Row="0" Classes="card" Margin="0,0,0,14">
                <StackPanel Spacing="11">
                  <TextBlock Classes="cardHead" Text="CF 命令"/>
                  <UniformGrid Columns="2">
                    <Button Classes="cmd" Margin="0,0,4,7" Content="LOAD_RECIPE" Command="{Binding CfLoadRecipeCommand}"/>
                    <Button Classes="cmd" Margin="4,0,0,7" Content="GET_RESULT" Command="{Binding CfGetResultCommand}"/>
                    <Button Classes="cmd" Margin="0,0,4,7" Content="SAVE_CONFIG" Command="{Binding CfSaveConfigCommand}"/>
                    <Button Classes="cmd" Margin="4,0,0,7" Content="SAVE_RECIPE" Command="{Binding CfSaveRecipeCommand}"/>
                    <Button Classes="cmd" Margin="0,0,4,0" Content="REFRESH" Command="{Binding RefreshCommand}"/>
                    <Button Classes="cmd" Margin="4,0,0,0" Content="GRAB" IsEnabled="False" ToolTip.Tip="MIL 專屬，新版未啟用"/>
                    <Button Classes="cmd" Margin="0,7,4,0" Content="ALIGN" IsEnabled="False" ToolTip.Tip="MIL 專屬，新版未啟用"/>
                    <Button Classes="cmd" Margin="4,7,0,0" Content="STOP" IsEnabled="False" ToolTip.Tip="MIL 專屬，新版未啟用"/>
                  </UniformGrid>
                </StackPanel>
              </Border>
              <Border Grid.Row="1" Classes="card">
                <DockPanel>
                  <TextBlock DockPanel.Dock="Top" Classes="cardHead" Text="配方" Margin="0,0,0,10"/>
                  <Button DockPanel.Dock="Bottom" Classes="primary" Content="儲存配方" HorizontalAlignment="Stretch"
                          Command="{Binding CfSaveRecipeCommand}"/>
                  <StackPanel Spacing="10">
                    <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding Store.RecipeNames}"
                              SelectedItem="{Binding Store.SelectedRecipe}"/>
                    <UniformGrid Columns="2">
                      <Border Background="{DynamicResource Bg3}" BorderBrush="{DynamicResource Line}" BorderThickness="1"
                              CornerRadius="{DynamicResource Rad}" Padding="8,10" Margin="0,0,4,8">
                        <StackPanel><TextBlock Classes="dim" FontSize="10" Text="BTH" Margin="0,0,0,3"/>
                          <TextBlock Classes="mono" FontSize="14" FontWeight="SemiBold" Text="{Binding Store.PrimaryZone.BrightThreshold}"/></StackPanel>
                      </Border>
                      <Border Background="{DynamicResource Bg3}" BorderBrush="{DynamicResource Line}" BorderThickness="1"
                              CornerRadius="{DynamicResource Rad}" Padding="8,10" Margin="4,0,0,8">
                        <StackPanel><TextBlock Classes="dim" FontSize="10" Text="DTH" Margin="0,0,0,3"/>
                          <TextBlock Classes="mono" FontSize="14" FontWeight="SemiBold" Text="{Binding Store.PrimaryZone.DarkThreshold}"/></StackPanel>
                      </Border>
                      <Border Background="{DynamicResource Bg3}" BorderBrush="{DynamicResource Line}" BorderThickness="1"
                              CornerRadius="{DynamicResource Rad}" Padding="8,10" Margin="0,0,4,0">
                        <StackPanel><TextBlock Classes="dim" FontSize="10" Text="PitchX" Margin="0,0,0,3"/>
                          <TextBlock Classes="mono" FontSize="14" FontWeight="SemiBold" Text="{Binding Store.PrimaryZone.PitchX}"/></StackPanel>
                      </Border>
                      <Border Background="{DynamicResource Bg3}" BorderBrush="{DynamicResource Line}" BorderThickness="1"
                              CornerRadius="{DynamicResource Rad}" Padding="8,10" Margin="4,0,0,0">
                        <StackPanel><TextBlock Classes="dim" FontSize="10" Text="PitchY" Margin="0,0,0,3"/>
                          <TextBlock Classes="mono" FontSize="14" FontWeight="SemiBold" Text="{Binding Store.PrimaryZone.PitchY}"/></StackPanel>
                      </Border>
                    </UniformGrid>
                  </StackPanel>
                </DockPanel>
              </Border>
            </Grid>

            <!-- 右：系統 log -->
            <Border Grid.Column="1" Classes="card" Padding="0">
              <DockPanel>
                <Border DockPanel.Dock="Top" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" Padding="8,4,8,0">
                  <StackPanel Orientation="Horizontal" Spacing="2">
                    <Button Classes="tab" Classes.active="{Binding IsLogSys}" Command="{Binding SetLogTabCommand}" CommandParameter="sys"
                            Content="{Binding SysLog.Count, StringFormat='系統 {0}'}"/>
                    <Button Classes="tab" Classes.active="{Binding IsLogError}" Command="{Binding SetLogTabCommand}" CommandParameter="error"
                            Content="{Binding ErrorLog.Count, StringFormat='錯誤 {0}'}"/>
                    <Button Classes="tab" Classes.active="{Binding IsLogWarn}" Command="{Binding SetLogTabCommand}" CommandParameter="warn"
                            Content="{Binding WarningLog.Count, StringFormat='警告 {0}'}"/>
                  </StackPanel>
                </Border>
                <Panel>
                  <ListBox IsVisible="{Binding IsLogSys}" ItemsSource="{Binding SysLog}" Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="svc:LogEntry">
                        <TextBlock FontFamily="{DynamicResource MonoFont}" FontSize="11.5" Text="{Binding Display}"
                                   Foreground="{Binding Level, Converter={StaticResource LogLevelToBrush}}"/>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                  <ListBox IsVisible="{Binding IsLogError}" ItemsSource="{Binding ErrorLog}" Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="svc:LogEntry">
                        <TextBlock FontFamily="{DynamicResource MonoFont}" FontSize="11.5" Foreground="{DynamicResource Bad}" Text="{Binding Display}"/>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                  <ListBox IsVisible="{Binding IsLogWarn}" ItemsSource="{Binding WarningLog}" Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="svc:LogEntry">
                        <TextBlock FontFamily="{DynamicResource MonoFont}" FontSize="11.5" Foreground="{DynamicResource Warn}" Text="{Binding Display}"/>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Panel>
              </DockPanel>
            </Border>
          </Grid>
        </Grid>

        <!-- ============ Step 1 ============ -->
        <Panel IsVisible="{Binding IsStep1}">
          <views:Step1View DataContext="{Binding Step1}"/>
        </Panel>

        <!-- ============ 配方編輯 ============ -->
        <Panel IsVisible="{Binding IsZone}">
          <views:ZoneParamEditorView DataContext="{Binding ZoneEditor}"/>
        </Panel>

        <!-- ============ 缺陷分類 ============ -->
        <Panel IsVisible="{Binding IsSort}">
          <views:DefectSortView DataContext="{Binding DefectSort}"/>
        </Panel>

        <!-- ============ 系統設定 ============ -->
        <Panel IsVisible="{Binding IsSettings}">
          <views:SystemSettingsView DataContext="{Binding SysSettings}"/>
        </Panel>

        <!-- ============ 單 CCD 設定（塊3：薄殼嵌 Step1View + ZoneParamEditorView） ============ -->
        <Panel IsVisible="{Binding IsSingleCcd}">
          <views:SingleCcdSetupView DataContext="{Binding SingleCcdSetup}"/>
        </Panel>

      </Panel>
    </Grid>
  </DockPanel>
</Window>
