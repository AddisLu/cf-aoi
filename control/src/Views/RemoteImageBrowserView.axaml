<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CfAoiControl.ViewModels"
        x:Class="CfAoiControl.Views.RemoteImageBrowserView"
        x:DataType="vm:RemoteImageBrowserViewModel"
        Title="從 IP 機載入影像" Width="720" Height="540"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Bg}" TextElement.Foreground="{DynamicResource Txt}">

  <DockPanel Margin="14">
    <!-- 路徑列 -->
    <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,10">
      <TextBlock Grid.Column="0" Text="路徑" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource Txt2}"/>
      <TextBox Grid.Column="1" Text="{Binding CurrentDir}" VerticalAlignment="Center"/>
      <Button Grid.Column="2" Classes="ghost" Content="前往" Margin="8,0,0,0" Command="{Binding GoCommand}"/>
    </Grid>

    <!-- 底部：狀態 + 載入/取消 -->
    <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto,Auto" Margin="0,10,0,0">
      <TextBlock Grid.Column="0" Classes="mono dim2" FontSize="11" VerticalAlignment="Center" Text="{Binding Status}"/>
      <Button Grid.Column="1" Name="BtnLoad" Classes="primary" Content="載入" Margin="0,0,8,0"/>
      <Button Grid.Column="2" Name="BtnCancel" Classes="ghost" Content="取消"/>
    </Grid>

    <!-- 目錄/影像清單（雙擊目錄進入、雙擊影像載入；單擊選取） -->
    <Border Classes="card" Padding="2">
      <ListBox Name="EntryList" ItemsSource="{Binding Entries}" SelectedItem="{Binding SelectedEntry}"
               Background="Transparent" BorderThickness="0">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="vm:RemoteEntry">
            <TextBlock Classes="mono" Text="{Binding Display}" Padding="6,3"/>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Border>
  </DockPanel>
</Window>
