<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CfAoiControl.Views.ZoneParamEditorView"
             x:Name="Root" x:CompileBindings="False" FontFamily="Arial">

  <DockPanel Margin="8">
    <!-- 頂列：配方 / 儲存 / 確認模式 -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,6">
      <TextBlock Text="配方" VerticalAlignment="Center"/>
      <ComboBox Width="200" ItemsSource="{Binding RecipeNames}" SelectedItem="{Binding SelectedRecipe}"/>
      <Button Content="儲存配方" Command="{Binding SaveCommand}"/>
      <CheckBox Content="批次更新前確認" IsChecked="{Binding UpdateWithAsk}"/>
    </StackPanel>

    <!-- 狀態列 -->
    <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}" Foreground="#555" Margin="0,6,0,0"/>

    <!-- 確認列（chkUpdateWithAsk）-->
    <Border DockPanel.Dock="Bottom" Background="#FFF3CD" CornerRadius="4" Padding="8,6" Margin="0,6,0,0"
            IsVisible="{Binding AwaitingConfirm}">
      <StackPanel Orientation="Horizontal" Spacing="10">
        <TextBlock Text="{Binding ConfirmText}" VerticalAlignment="Center" TextWrapping="Wrap"/>
        <Button Content="確認套用" Background="{StaticResource ColLightGreen}" Command="{Binding ConfirmApplyCommand}"/>
        <Button Content="取消" Background="{StaticResource ColPink}" Command="{Binding CancelApplyCommand}"/>
      </StackPanel>
    </Border>

    <Grid ColumnDefinitions="190,*,210">
      <!-- ===== 左：Region ===== -->
      <Border Grid.Column="0" BorderBrush="#A0A0A0" BorderThickness="1" CornerRadius="2" Padding="6" Margin="0,0,4,0">
        <StackPanel Spacing="6">
          <TextBlock Text="Region" FontWeight="Bold"/>
          <Grid ColumnDefinitions="Auto,*" >
            <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="StartX" VerticalAlignment="Center" Margin="0,2,6,2"/>
            <NumericUpDown Grid.Row="0" Grid.Column="1" Margin="0,2" Value="{Binding Buffer.StartX}" Increment="1"/>
            <TextBlock Grid.Row="1" Text="StartY" VerticalAlignment="Center" Margin="0,2,6,2"/>
            <NumericUpDown Grid.Row="1" Grid.Column="1" Margin="0,2" Value="{Binding Buffer.StartY}" Increment="1"/>
            <TextBlock Grid.Row="2" Text="EndX" VerticalAlignment="Center" Margin="0,2,6,2"/>
            <NumericUpDown Grid.Row="2" Grid.Column="1" Margin="0,2" Value="{Binding Buffer.EndX}" Increment="1"/>
            <TextBlock Grid.Row="3" Text="EndY" VerticalAlignment="Center" Margin="0,2,6,2"/>
            <NumericUpDown Grid.Row="3" Grid.Column="1" Margin="0,2" Value="{Binding Buffer.EndY}" Increment="1"/>
          </Grid>
          <Button Content="套用範圍到勾選 ROI" HorizontalAlignment="Stretch" Command="{Binding ApplyRoiRangeCommand}"/>

          <Separator/>
          <TextBlock Text="批次位移（勾選 ROI，X 夾 0~8160）" FontSize="11" Foreground="#666" TextWrapping="Wrap"/>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="步進" VerticalAlignment="Center"/>
            <NumericUpDown Width="90" Value="{Binding ShiftStep}" Increment="1" Minimum="1"/>
          </StackPanel>
          <UniformGrid Columns="2" >
            <Button Content="X −" Margin="2" Command="{Binding ShiftRoiCommand}" CommandParameter="x-"/>
            <Button Content="X +" Margin="2" Command="{Binding ShiftRoiCommand}" CommandParameter="x+"/>
            <Button Content="Y −" Margin="2" Command="{Binding ShiftRoiCommand}" CommandParameter="y-"/>
            <Button Content="Y +" Margin="2" Command="{Binding ShiftRoiCommand}" CommandParameter="y+"/>
          </UniformGrid>
        </StackPanel>
      </Border>

      <!-- ===== 中：27 列參數 ===== -->
      <Border Grid.Column="1" BorderBrush="#A0A0A0" BorderThickness="1" CornerRadius="2" Padding="6" Margin="2,0">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Text="Parameters（勾選欲套用者 → Update）" FontWeight="Bold" Margin="0,0,0,4"/>
          <!-- 底部 3 鈕 -->
          <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="6" Margin="0,6,0,0">
            <Button Content="Clear All" Background="{StaticResource ColPink}" Command="{Binding ClearAllChkCommand}"/>
            <Button Content="Select All" Background="{StaticResource ColLightGreen}" Command="{Binding SelectAllChkCommand}"/>
            <Button Content="Update Params" Background="{StaticResource ColGoldenrod}" Foreground="White" Command="{Binding UpdateCheckedParamsCommand}"/>
          </StackPanel>

          <ScrollViewer>
            <ItemsControl ItemsSource="{Binding ParamRows}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="Auto,150,*,Auto,Auto" Margin="0,1">
                    <CheckBox Grid.Column="0" IsChecked="{Binding IsChecked}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding Display}" VerticalAlignment="Center"/>
                    <!-- 輸入：text / bool / combo 三選一 -->
                    <TextBox Grid.Column="2" Margin="2,0" Text="{Binding TextValue}" IsVisible="{Binding IsText}" HorizontalContentAlignment="Center"/>
                    <CheckBox Grid.Column="2" Margin="2,0" IsChecked="{Binding BoolValue}" IsVisible="{Binding IsBool}"/>
                    <ComboBox Grid.Column="2" Margin="2,0" HorizontalAlignment="Stretch"
                              ItemsSource="{Binding Options}" SelectedItem="{Binding EnumValue}" IsVisible="{Binding IsCombo}"/>
                    <TextBlock Grid.Column="3" Text="{Binding IpTag}" Foreground="#E07000" FontSize="10"
                               VerticalAlignment="Center" Margin="4,0"/>
                    <Button Grid.Column="4" Content="Update" Margin="2,0"
                            Command="{Binding #Root.DataContext.UpdateParamCommand}" CommandParameter="{Binding}"/>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </DockPanel>
      </Border>

      <!-- ===== 右：ROI 勾選 ===== -->
      <Border Grid.Column="2" BorderBrush="#A0A0A0" BorderThickness="1" CornerRadius="2" Padding="6" Margin="4,0,0,0">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Text="ROI（勾選 = 套用目標；點選載入參數）" FontWeight="Bold" Margin="0,0,0,4" TextWrapping="Wrap"/>
          <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Rois}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2">
                    <CheckBox IsChecked="{Binding IsChecked}" VerticalAlignment="Center"/>
                    <Button Content="{Binding Label}" Background="Transparent"
                            Command="{Binding #Root.DataContext.LoadRoiToBufferCommand}" CommandParameter="{Binding}"/>
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </DockPanel>
      </Border>
    </Grid>
  </DockPanel>
</UserControl>
