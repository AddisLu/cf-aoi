<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CfAoiControl.Views.ZoneParamEditorView"
             x:Name="Root" x:CompileBindings="False">

  <DockPanel Margin="8">
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
      <TextBlock Text="配方" VerticalAlignment="Center"/>
      <ComboBox ItemsSource="{Binding RecipeNames}" SelectedItem="{Binding SelectedRecipe}" Width="160"/>
      <TextBlock Text="Zone" VerticalAlignment="Center"/>
      <ComboBox ItemsSource="{Binding Zones}" SelectedItem="{Binding SelectedZone}" Width="320"
                DisplayMemberBinding="{Binding ZoneLabel}"/>
      <Button Content="儲存" Command="{Binding SaveCommand}"/>
      <Button Content="複製演算法參數到全部 zone" Command="{Binding CopyToAllCommand}"/>
    </StackPanel>
    <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}" Margin="0,8,0,0" Foreground="#555"/>

    <ScrollViewer>
      <StackPanel Spacing="8" DataContext="{Binding SelectedZone}">
        <!-- ROI -->
        <Expander Header="ROI 範圍" IsExpanded="True">
          <StackPanel Spacing="6" Margin="8">
            <Grid ColumnDefinitions="120,140,120,140" RowDefinitions="Auto,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="StartX" VerticalAlignment="Center"/>
              <TextBox  Grid.Row="0" Grid.Column="1" Text="{Binding StartX}"/>
              <TextBlock Grid.Row="0" Grid.Column="2" Text="StartY" VerticalAlignment="Center"/>
              <TextBox  Grid.Row="0" Grid.Column="3" Text="{Binding StartY}"/>
              <TextBlock Grid.Row="1" Grid.Column="0" Text="EndX" VerticalAlignment="Center"/>
              <TextBox  Grid.Row="1" Grid.Column="1" Text="{Binding EndX}"/>
              <TextBlock Grid.Row="1" Grid.Column="2" Text="EndY" VerticalAlignment="Center"/>
              <TextBox  Grid.Row="1" Grid.Column="3" Text="{Binding EndY}"/>
            </Grid>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="位移步進" VerticalAlignment="Center"/>
              <TextBox Text="{Binding #Root.DataContext.RoiShiftStep}" Width="70"/>
              <Button Content="X-" Command="{Binding #Root.DataContext.ShiftRoiCommand}" CommandParameter="x-"/>
              <Button Content="X+" Command="{Binding #Root.DataContext.ShiftRoiCommand}" CommandParameter="x+"/>
              <Button Content="Y-" Command="{Binding #Root.DataContext.ShiftRoiCommand}" CommandParameter="y-"/>
              <Button Content="Y+" Command="{Binding #Root.DataContext.ShiftRoiCommand}" CommandParameter="y+"/>
            </StackPanel>
          </StackPanel>
        </Expander>

        <!-- Algorithm -->
        <Expander Header="演算法 / 前處理" IsExpanded="True">
          <Grid Margin="8" ColumnDefinitions="180,220">
            <Grid.RowDefinitions>
              <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
              <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
              <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
              <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
              <RowDefinition/><RowDefinition/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="ImagePreproc"/>
            <ComboBox Grid.Row="0" Grid.Column="1" HorizontalAlignment="Stretch"
                      ItemsSource="{Binding #Root.DataContext.ImagePreprocValues}" SelectedItem="{Binding ImagePreproc}"/>
            <TextBlock Grid.Row="1" Text="SmoothTimes"/>      <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SmoothTimes}"/>
            <TextBlock Grid.Row="2" Text="SmoothTimes2"/>     <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SmoothTimes2}"/>
            <TextBlock Grid.Row="3" Text="DarkThreshold (DTH)"/>  <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding DarkThreshold}"/>
            <TextBlock Grid.Row="4" Text="BrightThreshold (BTH)"/><TextBox Grid.Row="4" Grid.Column="1" Text="{Binding BrightThreshold}"/>
            <TextBlock Grid.Row="5" Text="SobelDetectEnable"/> <CheckBox Grid.Row="5" Grid.Column="1" IsChecked="{Binding SobelDetectEnable}"/>
            <TextBlock Grid.Row="6" Text="SobelSmoothTimes"/>  <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding SobelSmoothTimes}"/>
            <TextBlock Grid.Row="7" Text="SobelSmoothTimes2"/> <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding SobelSmoothTimes2}"/>
            <TextBlock Grid.Row="8" Text="SobelDarkThreshold"/><TextBox Grid.Row="8" Grid.Column="1" Text="{Binding SobelDarkThreshold}"/>
            <TextBlock Grid.Row="9" Text="SobelBrightThreshold"/><TextBox Grid.Row="9" Grid.Column="1" Text="{Binding SobelBrightThreshold}"/>
            <TextBlock Grid.Row="10" Text="AlgorithmWay"/>     <TextBox Grid.Row="10" Grid.Column="1" Text="{Binding AlgorithmWay}"/>
            <TextBlock Grid.Row="11" Text="AlgorithmCompare"/>
            <ComboBox Grid.Row="11" Grid.Column="1" HorizontalAlignment="Stretch"
                      ItemsSource="{Binding #Root.DataContext.AlgorithmCompareOptions}" SelectedItem="{Binding AlgorithmCompare}"/>
            <TextBlock Grid.Row="12" Text="M_AlgorithmWayCompare"/>
            <ComboBox Grid.Row="12" Grid.Column="1" HorizontalAlignment="Stretch"
                      ItemsSource="{Binding #Root.DataContext.AlgorithmWayCompareValues}" SelectedItem="{Binding AlgorithmWayCompare}"/>
            <TextBlock Grid.Row="13" Text="Adjustment"/>       <TextBox Grid.Row="13" Grid.Column="1" Text="{Binding Adjustment}"/>
            <TextBlock Grid.Row="14" Text="PitchTime"/>        <TextBox Grid.Row="14" Grid.Column="1" Text="{Binding PitchTime}"/>
            <TextBlock Grid.Row="15" Text="ChooseAmount"/>     <TextBox Grid.Row="15" Grid.Column="1" Text="{Binding ChooseAmount}"/>
            <TextBlock Grid.Row="16" Text="PitchX"/>           <TextBox Grid.Row="16" Grid.Column="1" Text="{Binding PitchX}"/>
            <TextBlock Grid.Row="17" Text="PitchY"/>           <TextBox Grid.Row="17" Grid.Column="1" Text="{Binding PitchY}"/>
            <TextBlock Grid.Row="18" Text="SearchX"/>          <TextBox Grid.Row="18" Grid.Column="1" Text="{Binding SearchX}"/>
            <TextBlock Grid.Row="19" Text="SearchY"/>          <TextBox Grid.Row="19" Grid.Column="1" Text="{Binding SearchY}"/>
            <TextBlock Grid.Row="20" Text="EdgePassRatio"/>    <TextBox Grid.Row="20" Grid.Column="1" Text="{Binding EdgePassRatio}"/>
            <TextBlock Grid.Row="21" Text="EdgePassThreshold"/><TextBox Grid.Row="21" Grid.Column="1" Text="{Binding EdgePassThreshold}"/>
          </Grid>
        </Expander>

        <!-- Filter -->
        <Expander Header="Blob 過濾" IsExpanded="True">
          <Grid Margin="8" ColumnDefinitions="200,220">
            <Grid.RowDefinitions>
              <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
              <RowDefinition/><RowDefinition/><RowDefinition/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="BlobMaxSize"/> <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding BlobMaxSize}"/>
            <TextBlock Grid.Row="1" Text="BlobMinSize"/> <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding BlobMinSize}"/>
            <TextBlock Grid.Row="2" Text="BlobElongation"/> <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding BlobElongation}"/>
            <TextBlock Grid.Row="3" Text="BlobFeretElong"/> <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding BlobFeretElong}"/>
            <TextBlock Grid.Row="4" Text="BlobDarkMergeDistance"/> <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding BlobDarkMergeDistance}"/>
            <TextBlock Grid.Row="5" Text="BlobBrightMergeDistance"/> <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding BlobBrightMergeDistance}"/>
            <TextBlock Grid.Row="6" Text="BlobAllMergeDistance"/> <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding BlobAllMergeDistance}"/>
          </Grid>
        </Expander>
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</UserControl>
