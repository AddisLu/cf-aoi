<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CfAoiControl.ViewModels"
             xmlns:m="using:CfAoiControl.Models"
             xmlns:ctrl="using:CfAoiControl.Controls"
             x:Class="CfAoiControl.Views.Step1View"
             x:DataType="vm:Step1ViewModel">

  <DockPanel Background="{DynamicResource Bg}" TextElement.Foreground="{DynamicResource Txt}">

    <!-- 標題列 -->
    <Grid DockPanel.Dock="Top" Margin="18,18,18,12" ColumnDefinitions="*,Auto">
      <TextBlock Grid.Column="0" Classes="h1" Text="Step 1 · 演算法驗證" VerticalAlignment="Center"/>
      <TextBlock Grid.Column="1" Classes="mono dim" FontSize="12" VerticalAlignment="Center" Text="離線分析 · network-clean"/>
    </Grid>

    <!-- 自動生成警告 -->
    <Border DockPanel.Dock="Top" Margin="18,0,18,12" Background="{DynamicResource WarnBg}"
            BorderBrush="{DynamicResource Warn}" BorderThickness="1" CornerRadius="{DynamicResource Rad}"
            Padding="13,9" IsVisible="{Binding ShowAutoGenWarning}">
      <StackPanel Orientation="Horizontal" Spacing="10">
        <Ellipse Width="7" Height="7" Fill="{DynamicResource Warn}" VerticalAlignment="Center"/>
        <TextBlock FontSize="12" Foreground="{DynamicResource WarnTx}" TextWrapping="Wrap"
                   Text="⚠ 配方為自動生成，請確認 PitchX / PitchY 是否符合實際影像。"/>
      </StackPanel>
    </Border>

    <!-- 8 格狀態列 -->
    <Border DockPanel.Dock="Bottom" Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}"
            BorderThickness="1" CornerRadius="{DynamicResource Rad}" Margin="18,0,18,18" Padding="0">
      <StackPanel Orientation="Horizontal">
        <TextBlock Classes="mono dim2" FontSize="11" Padding="13,6" Text="{Binding ImageSizeText}"/>
        <TextBlock Classes="mono dim2" FontSize="11" Padding="13,6" Text="{Binding AxisText}"/>
        <TextBlock Classes="mono dim2" FontSize="11" Padding="13,6" Text="{Binding ValueText}"/>
        <TextBlock Classes="mono dim2" FontSize="11" Padding="13,6" Text="{Binding ZoomText}"/>
        <TextBlock Classes="mono dim2" FontSize="11" Padding="13,6" Text="{Binding SelectedText}"/>
        <TextBlock Classes="mono dim2" FontSize="11" Padding="13,6" Text="{Binding RecipeText}"/>
        <TextBlock Classes="mono dim2" FontSize="11" Padding="13,6" Text="{Binding RegionText}"/>
        <TextBlock Classes="mono" FontSize="11" FontWeight="Bold" Padding="13,6" Text="{Binding DefectCntText}"
                   Foreground="{Binding DefectCntAtCap, Converter={StaticResource AtCapToBrush}}"/>
      </StackPanel>
    </Border>

    <Grid Margin="18,0,18,12" ColumnDefinitions="*,330">
      <!-- ===== 左欄：影像區 + 缺陷縮圖牆 ===== -->
      <Grid Grid.Column="0" RowDefinitions="70*,30*" Margin="0,0,13,0">
        <!-- 黑底影像區：可縮放/平移/量測 + 缺陷框 overlay -->
        <Border Grid.Row="0" CornerRadius="{DynamicResource Rad}" ClipToBounds="True"
                BorderBrush="{DynamicResource Line}" BorderThickness="1">
          <Grid RowDefinitions="*,Auto">
            <Border Grid.Row="0" Name="Viewport" Background="{DynamicResource ImageBackdrop}"
                    ClipToBounds="True" Focusable="True">
              <Panel>
                <Canvas Name="ContentRoot" RenderTransformOrigin="0,0" x:CompileBindings="False">
                  <Image Name="ImgDisplay" Source="{Binding SourceBitmap}"
                         Width="{Binding ImageWidth}" Height="{Binding ImageHeight}"
                         RenderOptions.BitmapInterpolationMode="None"/>
                  <ctrl:DefectOverlayControl Name="DefectOverlay" IsHitTestVisible="False"
                                             Width="{Binding ImageWidth}" Height="{Binding ImageHeight}"/>
                </Canvas>
                <Canvas Name="RoiOverlay" IsHitTestVisible="False"/>
                <Canvas Name="MeasureOverlay" IsHitTestVisible="False"/>
                <TextBlock Margin="12,10" VerticalAlignment="Top" HorizontalAlignment="Left"
                           FontFamily="{DynamicResource MonoFont}" FontSize="11" Foreground="#80FFFFFF"
                           Text="{Binding ImageSizeText, StringFormat='INSPECTION IMAGE · {0}'}"/>
              </Panel>
            </Border>
            <!-- 工具列 -->
            <Border Grid.Row="1" Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}" BorderThickness="0,1,0,0">
              <StackPanel Orientation="Horizontal" Spacing="8" Margin="8,6">
                <Button Name="BtnFit" Classes="ghost" Content="Fit"/>
                <Button Classes="ghost" Content="刷新標示" Command="{Binding RefreshOverlayCommand}"
                        ToolTip.Tip="從目前缺陷清單重畫大圖圓圈（不需重跑 Test）"/>
                <Button Name="BtnRoi" Classes="ghost" Content="框 ROI"
                        ToolTip.Tip="開啟後在影像上拖矩形框出 ROI(寫回配方 StartX/Y/EndX/Y);再按一次關閉"/>
                <Button Name="BtnRoiClear" Classes="ghost" Content="ROI 全幅(-1)"
                        ToolTip.Tip="清除 ROI → -1 = 全幅檢測"/>
                <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource Txt3}"
                           Text="左鍵拖曳平移 · 點缺陷選取 · 滾輪/雙指縮放 · 按住 M 量 Pitch · 框 ROI 拖矩形（中鍵/空白+拖亦可平移）"/>
              </StackPanel>
            </Border>
          </Grid>
        </Border>

        <!-- 缺陷縮圖牆 -->
        <Border Grid.Row="1" Classes="card" Padding="2" Margin="0,13,0,0">
          <ListBox Name="ThumbList" ItemsSource="{Binding Thumbs}" SelectedItem="{Binding SelectedThumb}" Background="Transparent" BorderThickness="0">
            <ListBox.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:DefectThumb">
                <StackPanel Width="74" Margin="2">
                  <Image Source="{Binding Image}" Width="64" Height="64"/>
                  <TextBlock Text="{Binding Label}" Classes="mono" FontSize="10" HorizontalAlignment="Center"
                             Foreground="{DynamicResource Txt2}"/>
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Border>
      </Grid>

      <!-- ===== 右欄：Action + 參數 ===== -->
      <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="13">
          <!-- Action -->
          <Border Classes="card">
            <StackPanel Spacing="8">
              <TextBlock Classes="cardHead" Text="操作"/>
              <UniformGrid Columns="2">
                <Button Classes="primary" Margin="0,0,4,6" Content="載入影像" Command="{Binding BrowseImageCommand}"/>
                <Button Classes="green" Margin="4,0,0,6" Content="▶ Test 送 IP" Command="{Binding RunAnalysisCommand}"/>
                <Button Classes="ghost" Margin="0,0,4,0" Content="儲存配方" Command="{Binding SaveRecipeCommand}"/>
                <CheckBox Margin="4,0,0,0" Content="Debug 存全圖" IsChecked="{Binding DebugSaveDefectPatches}"
                          ToolTip.Tip="勾選：Test 時請 IP 存全部缺陷小圖（供 DefectSort 分類）。不勾只存結果+overlay（調參較快）。初值來自 ShareSetting.DebugAlgorithm。"/>
              </UniformGrid>
              <Border Background="{DynamicResource Bg3}" BorderBrush="{DynamicResource Line}" BorderThickness="1"
                      CornerRadius="{DynamicResource Rad}" Padding="8,6">
                <TextBlock Classes="dim" FontSize="11" TextWrapping="Wrap"
                           Text="（Add/Delete Rect、Remap、HistEq 等 MIL 專屬功能新版未啟用）"/>
              </Border>
              <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsAnalyzing}" Height="4"/>
            </StackPanel>
          </Border>

          <!-- 參數（快速調參 + 配方選擇）-->
          <Border Classes="card">
            <StackPanel Spacing="10">
              <TextBlock Classes="cardHead" Text="快速調參 (M_DetectRoi)"/>
              <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="配方" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource Txt2}"/>
                <ComboBox Grid.Row="0" Grid.Column="1" HorizontalAlignment="Stretch"
                          ItemsSource="{Binding Store.RecipeNames}" SelectedItem="{Binding Store.SelectedRecipe}"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="BrightThreshold" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource Txt2}"/>
                <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding Store.PrimaryZone.BrightThreshold}" Increment="0.05" Minimum="1.01" Maximum="3.0" FormatString="F2"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="DarkThreshold" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource Txt2}"/>
                <NumericUpDown Grid.Row="2" Grid.Column="1" Value="{Binding Store.PrimaryZone.DarkThreshold}" Increment="0.05" Minimum="0.1" Maximum="0.99" FormatString="F2"/>
                <TextBlock Grid.Row="3" Grid.Column="0" Text="PitchX" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource Txt2}"/>
                <NumericUpDown Grid.Row="3" Grid.Column="1" Value="{Binding Store.PrimaryZone.PitchX}" Increment="1" Minimum="1"/>
                <TextBlock Grid.Row="4" Grid.Column="0" Text="PitchY" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource Txt2}"/>
                <NumericUpDown Grid.Row="4" Grid.Column="1" Value="{Binding Store.PrimaryZone.PitchY}" Increment="1" Minimum="1"/>
              </Grid>

              <!-- FFT 估算 Pitch -->
              <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <Button Classes="ghost" Content="FFT 估算 Pitch" Command="{Binding EstimateFftCommand}"/>
                  <Button Classes="primary" Content="套用" Command="{Binding ApplyFftCommand}" IsVisible="{Binding HasFftResult}"/>
                  <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsEstimatingFft}" Width="60" Height="4" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock FontSize="12" Foreground="{DynamicResource Ok}" TextWrapping="Wrap"
                           IsVisible="{Binding HasFftResult}" Text="{Binding FftResultText}"/>
              </StackPanel>

              <TextBlock Classes="dim" FontSize="11" Text="檢測上限：10000（IP 端固定，不可改）"/>
              <TextBlock Classes="dim" FontSize="11" TextWrapping="Wrap"
                         Text="（完整 32 參數編輯在「配方編輯」；此處為快速調參）"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Grid>
  </DockPanel>
</UserControl>
