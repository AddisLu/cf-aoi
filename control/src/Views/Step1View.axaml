<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CfAoiControl.ViewModels"
             xmlns:m="using:CfAoiControl.Models"
             xmlns:ctrl="using:CfAoiControl.Controls"
             x:Class="CfAoiControl.Views.Step1View"
             x:DataType="vm:Step1ViewModel" FontFamily="Arial">

  <DockPanel>
    <!-- 8 格狀態列 -->
    <Border DockPanel.Dock="Bottom" Background="#F0F0F0" BorderBrush="#C0C0C0" BorderThickness="0,1,0,0" Padding="6,3">
      <StackPanel Orientation="Horizontal" Spacing="10">
        <TextBlock Text="{Binding ImageSizeText}"/>
        <TextBlock Text="{Binding AxisText}"/>
        <TextBlock Text="{Binding ValueText}"/>
        <TextBlock Text="{Binding ZoomText}"/>
        <TextBlock Text="{Binding SelectedText}"/>
        <TextBlock Text="{Binding RecipeText}"/>
        <TextBlock Text="{Binding RegionText}"/>
        <TextBlock Text="{Binding DefectCntText}" FontWeight="Bold"
                   Foreground="{Binding DefectCntAtCap, Converter={StaticResource AtCapToBrush}}"/>
      </StackPanel>
    </Border>

    <Grid ColumnDefinitions="65*,35*">
      <!-- ===== 左欄：影像區 + 缺陷縮圖牆 ===== -->
      <Grid Grid.Column="0" RowDefinitions="70*,30*" Margin="3">
        <!-- 黑底影像區：可縮放/平移/量測 + 缺陷框 overlay -->
        <Border Grid.Row="0" Margin="1">
          <Grid RowDefinitions="*,Auto">
            <Border Grid.Row="0" Name="Viewport" Background="{StaticResource ColBlack}"
                    ClipToBounds="True" Focusable="True">
              <Panel>
                <!-- 影像 + 缺陷 overlay（content 座標 = 原始像素；MatrixTransform 統一縮放/平移）-->
                <Canvas Name="ContentRoot" RenderTransformOrigin="0,0" x:CompileBindings="False">
                  <Image Name="ImgDisplay" Source="{Binding SourceBitmap}"
                         Width="{Binding ImageWidth}" Height="{Binding ImageHeight}"
                         RenderOptions.BitmapInterpolationMode="None"/>
                  <!-- 缺陷框（亮紅/暗藍/選中綠），單一控制項畫全部，隨 MatrixTransform -->
                  <ctrl:DefectOverlayControl Name="DefectOverlay" IsHitTestVisible="False"
                                             Width="{Binding ImageWidth}" Height="{Binding ImageHeight}"/>
                </Canvas>
                <!-- 量測標記層（螢幕座標，不隨 content 變換縮放）-->
                <Canvas Name="MeasureOverlay" IsHitTestVisible="False"/>
              </Panel>
            </Border>
            <!-- 工具列：Fit + 操作提示 -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="2">
              <Button Name="BtnFit" Content="Fit"/>
              <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="#666"
                         Text="滾輪縮放 · 中鍵/空白+拖曳平移 · 按住 M 點兩格量 Pitch"/>
            </StackPanel>
          </Grid>
        </Border>

        <!-- 缺陷縮圖牆（listView1 LargeIcon）-->
        <Border Grid.Row="1" BorderBrush="#A0A0A0" BorderThickness="1" Background="White" Margin="1">
          <ListBox Name="ThumbList" ItemsSource="{Binding Thumbs}" SelectedItem="{Binding SelectedThumb}" Background="Transparent">
            <ListBox.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:DefectThumb">
                <StackPanel Width="74" Margin="2">
                  <Image Source="{Binding Image}" Width="64" Height="64"/>
                  <TextBlock Text="{Binding Label}" FontSize="10" HorizontalAlignment="Center"/>
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Border>
      </Grid>

      <!-- ===== 右欄：Action 按鈕 + 參數 ===== -->
      <Grid Grid.Column="1" RowDefinitions="Auto,*" Margin="3">
        <!-- Action -->
        <Border Grid.Row="0" BorderBrush="#A0A0A0" BorderThickness="1" CornerRadius="2" Padding="4" Margin="1">
          <StackPanel Spacing="4">
            <TextBlock Text="Action" FontWeight="Bold"/>
            <WrapPanel>
              <Button Width="80" Height="58" Margin="3" IsEnabled="False" ToolTip.Tip="用下方配方下拉選擇" Content="Load&#10;Recipe"/>
              <Button Width="80" Height="58" Margin="3" Content="Save&#10;Setting" Background="{StaticResource ColDodgerBlue}" Foreground="White" Command="{Binding SaveRecipeCommand}"/>
              <Button Width="80" Height="58" Margin="3" IsEnabled="False" ToolTip.Tip="MIL 專屬，新版未啟用" Content="Add Rect"/>
              <Button Width="80" Height="58" Margin="3" IsEnabled="False" ToolTip.Tip="MIL 專屬，新版未啟用" Content="Save&#10;Recipe"/>

              <Button Width="80" Height="58" Margin="3" Content="Load&#10;Image" Command="{Binding BrowseImageCommand}"/>
              <Button Width="80" Height="58" Margin="3" Content="Test" Background="{StaticResource ColLightGreen}" Command="{Binding RunAnalysisCommand}"/>
              <Button Width="80" Height="58" Margin="3" IsEnabled="False" ToolTip.Tip="MIL 專屬，新版未啟用" Content="Delete Rect" Background="{StaticResource ColOrangeRed}" Foreground="White"/>
              <CheckBox Width="80" Margin="3" Content="Debug" IsChecked="{Binding DebugSaveDefectPatches}"
                        ToolTip.Tip="勾選：Test 時請 IP 存全部缺陷小圖（供 DefectSort 分類）。不勾只存結果+overlay（調參較快）。"/>

              <Button Width="80" Height="58" Margin="3" IsEnabled="False" ToolTip.Tip="MIL 專屬，新版未啟用" Content="Load Multi&#10;Image"/>
              <Button Width="80" Height="58" Margin="3" IsEnabled="False" ToolTip.Tip="MIL 專屬，新版未啟用" Content="Draw Recipe Roi"/>
              <Button Width="80" Height="36" Margin="3" IsEnabled="False" ToolTip.Tip="MIL 專屬，新版未啟用" Content="Cut" Background="{StaticResource ColOrange}"/>
              <Button Width="80" Height="36" Margin="3" IsEnabled="False" ToolTip.Tip="需 MIL Remap" Content="Remap" Background="{StaticResource ColOrange}"/>
              <Button Width="80" Height="36" Margin="3" IsEnabled="False" ToolTip.Tip="需 MIL" Content="HistEq" Background="{StaticResource ColOrange}"/>
              <Button Width="80" Height="36" Margin="3" IsEnabled="False" ToolTip.Tip="MIL 專屬，新版未啟用" Content="Reload" Background="{StaticResource ColOrange}"/>
            </WrapPanel>
            <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsAnalyzing}" Height="4"/>
            <Border Background="#FFF3CD" CornerRadius="3" Padding="6,4" IsVisible="{Binding ShowAutoGenWarning}">
              <TextBlock TextWrapping="Wrap" FontSize="11" Text="⚠ 配方為自動生成，請確認 PitchX/PitchY！"/>
            </Border>
          </StackPanel>
        </Border>

        <!-- 參數（propertyGrid 類比：快速調參 + 配方選擇）-->
        <Border Grid.Row="1" BorderBrush="#A0A0A0" BorderThickness="1" CornerRadius="2" Padding="6" Margin="1,4,1,1">
          <StackPanel Spacing="8">
            <TextBlock Text="參數 (M_DetectRoi)" FontWeight="Bold"/>
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="配方" VerticalAlignment="Center" Margin="0,0,8,4"/>
              <ComboBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,4" HorizontalAlignment="Stretch"
                        ItemsSource="{Binding Store.RecipeNames}" SelectedItem="{Binding Store.SelectedRecipe}"/>
              <TextBlock Grid.Row="1" Grid.Column="0" Text="BrightThreshold" VerticalAlignment="Center" Margin="0,0,8,4"/>
              <NumericUpDown Grid.Row="1" Grid.Column="1" Margin="0,0,0,4" Value="{Binding Store.PrimaryZone.BrightThreshold}" Increment="0.05" Minimum="1.01" Maximum="3.0" FormatString="F2"/>
              <TextBlock Grid.Row="2" Grid.Column="0" Text="DarkThreshold" VerticalAlignment="Center" Margin="0,0,8,4"/>
              <NumericUpDown Grid.Row="2" Grid.Column="1" Margin="0,0,0,4" Value="{Binding Store.PrimaryZone.DarkThreshold}" Increment="0.05" Minimum="0.1" Maximum="0.99" FormatString="F2"/>
              <TextBlock Grid.Row="3" Grid.Column="0" Text="PitchX" VerticalAlignment="Center" Margin="0,0,8,4"/>
              <NumericUpDown Grid.Row="3" Grid.Column="1" Margin="0,0,0,4" Value="{Binding Store.PrimaryZone.PitchX}" Increment="1" Minimum="1"/>
              <TextBlock Grid.Row="4" Grid.Column="0" Text="PitchY" VerticalAlignment="Center" Margin="0,0,8,4"/>
              <NumericUpDown Grid.Row="4" Grid.Column="1" Value="{Binding Store.PrimaryZone.PitchY}" Increment="1" Minimum="1"/>
            </Grid>

            <!-- 功能 A：FFT 估算 Pitch（不自動覆蓋，看了再套用以對照手動值）-->
            <StackPanel Spacing="4">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Button Content="FFT 估算 Pitch" Command="{Binding EstimateFftCommand}"/>
                <Button Content="套用" Command="{Binding ApplyFftCommand}" IsVisible="{Binding HasFftResult}"/>
                <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsEstimatingFft}" Width="60" Height="4" VerticalAlignment="Center"/>
              </StackPanel>
              <TextBlock FontSize="12" Foreground="#0a6" TextWrapping="Wrap"
                         IsVisible="{Binding HasFftResult}" Text="{Binding FftResultText}"/>
            </StackPanel>

            <!-- 功能 B：檢測上限（唯讀）-->
            <TextBlock FontSize="11" Foreground="#888" Text="檢測上限：10000（IP 端固定，不可改）"/>
            <TextBlock FontSize="11" Foreground="#666" TextWrapping="Wrap"
                       Text="（完整 32 參數編輯在第二批 ZoneParamEditor；此處為快速調參）"/>
          </StackPanel>
        </Border>
      </Grid>
    </Grid>
  </DockPanel>
</UserControl>
