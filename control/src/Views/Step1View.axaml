<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CfAoiControl.ViewModels"
             xmlns:m="using:CfAoiControl.Models"
             x:Class="CfAoiControl.Views.Step1View"
             x:DataType="vm:Step1ViewModel">

  <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="8">
    <!-- 自動生成配方警告 -->
    <Border Grid.Row="0" Background="#FFF3CD" CornerRadius="4" Padding="12,8" Margin="0,0,0,8"
            IsVisible="{Binding ShowAutoGenWarning}">
      <TextBlock TextWrapping="Wrap" Text="⚠ 配方為自動生成，請確認 PitchX / PitchY 是否符合實際影像！"/>
    </Border>

    <!-- 影像 + 配方 + 快速調參 -->
    <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
      <StackPanel Spacing="4" Margin="0,0,16,0">
        <TextBlock Text="影像檔案"/>
        <StackPanel Orientation="Horizontal" Spacing="4">
          <TextBox Text="{Binding SelectedImagePath}" Width="340"/>
          <Button Content="瀏覽…" Command="{Binding BrowseImageCommand}"/>
        </StackPanel>
      </StackPanel>
      <StackPanel Spacing="4" Margin="0,0,16,0">
        <TextBlock Text="配方"/>
        <ComboBox ItemsSource="{Binding RecipeNames}" SelectedItem="{Binding SelectedRecipe}" Width="160"/>
      </StackPanel>
      <StackPanel Spacing="4" Margin="0,0,16,0">
        <TextBlock Text="快速調參（DIV 比例域）"/>
        <Grid ColumnDefinitions="Auto,90,Auto,90" RowDefinitions="Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="BrightTh" VerticalAlignment="Center"/>
          <NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding BrightThreshold}" Increment="0.05" Minimum="1.01" Maximum="3.0" FormatString="F2"/>
          <TextBlock Grid.Row="0" Grid.Column="2" Text="DarkTh" VerticalAlignment="Center"/>
          <NumericUpDown Grid.Row="0" Grid.Column="3" Value="{Binding DarkThreshold}" Increment="0.05" Minimum="0.1" Maximum="0.99" FormatString="F2"/>
          <TextBlock Grid.Row="1" Grid.Column="0" Text="PitchX" VerticalAlignment="Center"/>
          <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding PitchX}" Increment="1" Minimum="1"/>
          <TextBlock Grid.Row="1" Grid.Column="2" Text="PitchY" VerticalAlignment="Center"/>
          <NumericUpDown Grid.Row="1" Grid.Column="3" Value="{Binding PitchY}" Increment="1" Minimum="1"/>
        </Grid>
      </StackPanel>
      <StackPanel VerticalAlignment="Bottom" Spacing="4">
        <Button Content="▶ 送 IP 分析" Command="{Binding RunAnalysisCommand}"
                Background="#0078d4" Foreground="White" Padding="16,8"/>
        <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsAnalyzing}" Height="4"/>
      </StackPanel>
    </WrapPanel>

    <!-- 缺陷清單 + patch -->
    <Grid Grid.Row="2" ColumnDefinitions="*,320">
      <DataGrid ItemsSource="{Binding Defects}" SelectedItem="{Binding SelectedDefect}"
                AutoGenerateColumns="False" CanUserSortColumns="True" IsReadOnly="True"
                GridLinesVisibility="Horizontal">
        <DataGrid.Columns>
          <DataGridTextColumn Header="類型" Binding="{Binding Type}" Width="110"/>
          <DataGridTextColumn Header="X" Binding="{Binding GlobalPosX}" Width="80"/>
          <DataGridTextColumn Header="Y" Binding="{Binding GlobalPosY}" Width="80"/>
          <DataGridTextColumn Header="尺寸" Binding="{Binding SizeStr}" Width="100"/>
          <DataGridTextColumn Header="GL_Mean" Binding="{Binding GlMean}" Width="80"/>
          <DataGridTextColumn Header="AI" Binding="{Binding AiResult}" Width="70"/>
          <DataGridTextColumn Header="Score" Binding="{Binding AiScoreStr}" Width="70"/>
        </DataGrid.Columns>
      </DataGrid>

      <StackPanel Grid.Column="1" Margin="8,0,0,0" Spacing="6">
        <TextBlock Text="缺陷影像" FontWeight="Bold"/>
        <Border BorderBrush="#ccc" BorderThickness="1" Background="Black" Width="300" Height="300">
          <Image Source="{Binding SelectedDefectBitmap}" Stretch="Uniform"/>
        </Border>
        <StackPanel Orientation="Horizontal" Spacing="6">
          <Button Content="✓ 歸檔 OK" Command="{Binding ClassifyOkCommand}" Background="#2ecc71" Foreground="White"/>
          <Button Content="✗ 歸檔 NG" Command="{Binding ClassifyNgCommand}" Background="#e74c3c" Foreground="White"/>
        </StackPanel>
        <TextBlock Text="（OK/NG 歸檔供 AI 訓練資料蒐集）" FontSize="11" Foreground="#888"/>
      </StackPanel>
    </Grid>

    <!-- 結果摘要列 -->
    <Border Grid.Row="3" Padding="8,6" Background="#f3f4f6" Margin="0,8,0,0">
      <StackPanel Orientation="Horizontal" Spacing="16">
        <TextBlock Text="{Binding ResultSummary}" VerticalAlignment="Center"/>
        <Button Content="儲存配方" Command="{Binding SaveRecipeCommand}"/>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
