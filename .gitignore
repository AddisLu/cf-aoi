# ===== Build outputs =====
# C++ / CMake (IP)
ip/build/
**/build/
*.o
*.obj

# .NET (Control)
**/bin/
**/obj/
*.user
.vs/

# Python（模擬器/腳本的 bytecode 快取）
__pycache__/
*.pyc

# ===== Runtime-generated =====
# 執行期/部署期產生，不版控 (不包含測試配方->Control要使用)
output/
**/output/
*.log

# 配方 = 執行期/測試產物（runtime RecipeDir=~/cf-aoi/recipes，非此 repo 目錄）；
# 只保留 DEFAULT 樣板，其餘 selftest 產生的配方不版控。
recipes/
!recipes/DEFAULT/
!recipes/DEFAULT/**

# ===== Large reference material (1.4G) — 另外保存，不進 git =====
Reference/

# ===== 測試影像（大檔，Mac 端不需要） =====
test_images/*.tif
test_images/*.bmp

# ===== OS / editor junk =====
.DS_Store
*~
*.swp

# ===== 機器/相機相關（每機本地，不版控；用 *.example.json 當模板）=====
grab/cam_config.json
control/src/config/array_topology.json

# ===== Misc =====
/tmp/
